# EVerest Configuration for OCPP 1.6
# Auto-generated by entrypoint.sh with NUM_CONNECTORS={{ getenv "NUM_CONNECTORS" }}
{{ $n := conv.ToInt (getenv "NUM_CONNECTORS") }}active_modules:
{{- range $i := math.Seq 1 $n }}

  # --- Connector {{ $i }} ---
  evse_manager_{{ $i }}:
    module: EvseManager
    config_module:
      connector_id: {{ $i }}
      evse_id: "{{ printf "US*EVE*E%06d" $i }}"
      charge_mode: DC
      has_ventilation: true
      session_logging: true
      session_logging_path: /tmp/everest-logs
      max_current_import_A: 250
      max_current_export_A: 250
      ac_nominal_voltage: 400
      payment_enable_eim: true
      payment_enable_contract: false
    connections:
      bsp:
        - module_id: yeti_driver_{{ $i }}
          implementation_id: board_support
      powermeter_grid_side:
        - module_id: dc_supply_{{ $i }}
          implementation_id: powermeter
      slac:
        - module_id: slac_sim_{{ $i }}
          implementation_id: evse
      hlc:
        - module_id: evse_v2g_{{ $i }}
          implementation_id: charger
      powersupply_DC:
        - module_id: dc_supply_{{ $i }}
          implementation_id: main
      imd:
        - module_id: imd_sim_{{ $i }}
          implementation_id: main

  yeti_driver_{{ $i }}:
    module: YetiSimulator
    config_module:
      connector_id: {{ $i }}
      max_current_A_import: 500.0
      min_current_A_import: 0.0
      max_current_A_export: 500.0

  dc_supply_{{ $i }}:
    module: DCSupplySimulator
    config_implementation:
      main:
        max_current: 375.0
        max_power: 150000

  imd_sim_{{ $i }}:
    module: IMDSimulator

  slac_sim_{{ $i }}:
    module: SlacSimulator

  evse_v2g_{{ $i }}:
    module: EvseV2G
    config_module:
      device: eth0
      supported_DIN70121: true
      supported_ISO15118_2: true
      enable_sdp_server: {{ if eq $i 1 }}true{{ else }}false{{ end }}
    connections:
      security:
        - module_id: evse_security
          implementation_id: main

  ev_iso_{{ $i }}:
    module: PyEvJosev
    config_module:
      device: eth0
      supported_ISO15118_2: true
      supported_ISO15118_20_DC: true

  ev_manager_{{ $i }}:
    module: EvManager
    config_module:
      connector_id: {{ $i }}
      auto_enable: false
      auto_exec: false
      dc_max_power_limit: 100000
      dc_max_current_limit: 250
      dc_max_voltage_limit: 500
      dc_target_voltage: 400
      dc_target_current: 250
      dc_energy_capacity: 75000
    connections:
      ev_board_support:
        - module_id: yeti_driver_{{ $i }}
          implementation_id: ev_board_support
      slac:
        - module_id: slac_sim_{{ $i }}
          implementation_id: ev
      ev:
        - module_id: ev_iso_{{ $i }}
          implementation_id: ev

  evse_manager_{{ $i }}_api_sink:
    module: EnergyNode
    mapping:
      module:
        evse: {{ $i }}
    config_module:
      fuse_limit_A: 300.0
      phase_count: 3
    connections:
      energy_consumer:
        - module_id: evse_manager_{{ $i }}_ocpp_sink
          implementation_id: energy_grid
      powermeter:
        - module_id: yeti_driver_{{ $i }}
          implementation_id: powermeter

  evse_manager_{{ $i }}_ocpp_sink:
    module: EnergyNode
    mapping:
      module:
        evse: {{ $i }}
    config_module:
      fuse_limit_A: 300.0
      phase_count: 3
    connections:
      energy_consumer:
        - module_id: evse_manager_{{ $i }}
          implementation_id: energy_grid
{{ end }}
  # --- OCPP 1.6 Module ---
  ocpp:
    module: OCPP
    config_module:
      ChargePointConfigPath: /etc/everest/ocpp-config.json
      MessageLogPath: /tmp/everest-logs/ocpp
    connections:
      evse_manager:
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}
          implementation_id: evse
{{- end }}
      auth:
        - module_id: auth
          implementation_id: main
      reservation:
        - module_id: auth
          implementation_id: reservation
      system:
        - module_id: system
          implementation_id: main
      security:
        - module_id: evse_security
          implementation_id: main
      evse_energy_sink:
        - module_id: grid_connection_point
          implementation_id: external_limits
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}_ocpp_sink
          implementation_id: external_limits
{{- end }}

  # --- Security Module ---
  evse_security:
    module: EvseSecurity
    config_module:
      private_key_password: ""

  # --- Auth Module ---
  token_provider_1:
    module: DummyTokenProviderManual

  auth:
    module: Auth
    config_module:
      connection_timeout: 120
      selection_algorithm: PlugEvents
    connections:
      token_provider:
        - module_id: token_provider_1
          implementation_id: main
        - module_id: ocpp
          implementation_id: auth_provider
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}
          implementation_id: token_provider
{{- end }}
      token_validator:
        - module_id: ocpp
          implementation_id: auth_validator
      evse_manager:
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}
          implementation_id: evse
{{- end }}
      kvs:
        - module_id: persistent_store
          implementation_id: main

  # --- Energy Management (for Charging Profiles) ---
  energy_manager:
    module: EnergyManager
    config_module:
      slice_ampere: 5.0
      slice_watt: 5000
    connections:
      energy_trunk:
        - module_id: grid_connection_point
          implementation_id: energy_grid

  grid_connection_point:
    module: EnergyNode
    mapping:
      module:
        evse: 0
    config_module:
      fuse_limit_A: 300.0
      phase_count: 3
    connections:
      price_information: []
      energy_consumer:
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}_api_sink
          implementation_id: energy_grid
{{- end }}
      powermeter:
        - module_id: yeti_driver_1
          implementation_id: powermeter

  # --- API for Node-RED ---
  api:
    module: API
    connections:
      evse_manager:
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}
          implementation_id: evse
{{- end }}
      evse_energy_sink:
{{- range $i := math.Seq 1 $n }}
        - module_id: evse_manager_{{ $i }}_api_sink
          implementation_id: external_limits
{{- end }}

  # --- System Module ---
  system:
    module: System

  # --- Persistent Store (for Reservations) ---
  persistent_store:
    module: PersistentStore
    config_module:
      sqlite_db_file_path: /var/lib/everest/persistent_store.db

x-module-layout: {}
